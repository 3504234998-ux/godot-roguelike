[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/hud.gd" id="1_script"]

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1_script")

; ===== 左上角信息面板 =====
[node name="InfoPanel" type="Panel" parent="."]
offset_left = 12.0
offset_top = 12.0
offset_right = 280.0
offset_bottom = 130.0

[node name="MarginContainer" type="MarginContainer" parent="InfoPanel"]
anchors_preset = 15
offset_left = 10.0
offset_top = 8.0
offset_right = -10.0
offset_bottom = -8.0
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 8

[node name="VBoxContainer" type="VBoxContainer" parent="InfoPanel/MarginContainer"]
theme_override_constants/separation = 8

; ===== 等级行 =====
[node name="LevelBox" type="HBoxContainer" parent="InfoPanel/MarginContainer/VBoxContainer"]
theme_override_constants/separation = 6

[node name="LevelIcon" type="Label" parent="InfoPanel/MarginContainer/VBoxContainer/LevelBox"]
text = "★"
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(1.0, 0.85, 0.2, 1.0)

[node name="LevelLabel" type="Label" parent="InfoPanel/MarginContainer/VBoxContainer/LevelBox"]
unique_name_in_owner = true
text = "Lv. 1"
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(1.0, 0.85, 0.2, 1.0)

; ===== HP 血条行 =====
[node name="HPBox" type="HBoxContainer" parent="InfoPanel/MarginContainer/VBoxContainer"]
theme_override_constants/separation = 6

[node name="HPIcon" type="Label" parent="InfoPanel/MarginContainer/VBoxContainer/HPBox"]
text = "♥"
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(1.0, 0.25, 0.25, 1.0)

[node name="HPBar" type="TextureProgressBar" parent="InfoPanel/MarginContainer/VBoxContainer/HPBox"]
unique_name_in_owner = true
size_flags_horizontal = 3
custom_minimum_size = Vector2(0, 16)
value = 100.0
max_value = 100.0
fill_mode = 0

[node name="HPLabel" type="Label" parent="InfoPanel/MarginContainer/VBoxContainer/HPBox"]
unique_name_in_owner = true
text = "100/100"
custom_minimum_size = Vector2(72, 0)
horizontal_alignment = 2
theme_override_font_sizes/font_size = 12
theme_override_colors/font_color = Color(0.85, 0.85, 0.8, 1.0)

; ===== EXP 经验条行 =====
[node name="EXPBox" type="HBoxContainer" parent="InfoPanel/MarginContainer/VBoxContainer"]
theme_override_constants/separation = 6

[node name="EXPIcon" type="Label" parent="InfoPanel/MarginContainer/VBoxContainer/EXPBox"]
text = "◆"
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.5, 0.4, 1.0, 1.0)

[node name="ExpBar" type="TextureProgressBar" parent="InfoPanel/MarginContainer/VBoxContainer/EXPBox"]
unique_name_in_owner = true
size_flags_horizontal = 3
custom_minimum_size = Vector2(0, 12)
value = 0.0
max_value = 50.0
fill_mode = 0

; ===== 右上角时间显示 =====
[node name="TimePanel" type="Panel" parent="."]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -110.0
offset_top = 12.0
offset_right = -12.0
offset_bottom = 46.0

[node name="TimeMargin" type="MarginContainer" parent="TimePanel"]
anchors_preset = 15
offset_left = 10.0
offset_top = 4.0
offset_right = -10.0
offset_bottom = -4.0

[node name="TimeLabel" type="Label" parent="TimePanel/TimeMargin"]
unique_name_in_owner = true
text = "00:00"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.9, 0.9, 0.8, 1.0)
